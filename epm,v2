<script>
const EPM_BACKEND_BASE = "https://epm-ai-estimator.onrender.com";
const EPM_BACKEND_URL = EPM_BACKEND_BASE + "/api/estimate";
const EPM_PHONE = "tel:+12818148804";

let lastEstimateText = "";

async function getEpmEstimate() {
  const address = document.getElementById("epmAddress").value.trim();
  const selected = Array.from(document.querySelectorAll(".services input:checked")).map(function(x) { return x.value; });
  const result = document.getElementById("epmResult");
  const button = document.getElementById("epmGenerateBtn");

  if (!address) {
    alert("Please enter a property address.");
    return;
  }

  if (selected.length === 0) {
    alert("Please select at least one service.");
    return;
  }

  button.disabled = true;
  button.textContent = "Generating Estimate...";
  result.innerHTML = '<div class="epm-loading">Generating aerial view, street view, EPM Home Profile, and quote...</div>';

  try {
    const res = await fetch(EPM_BACKEND_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        address: address,
        services: selected
      })
    });

    const data = await res.json();

    if (!res.ok) {
      throw new Error(data.error || "Estimate failed.");
    }

    renderEstimate(data);
  } catch (err) {
    result.innerHTML = '<div class="epm-error">' + err.message + '</div>';
  } finally {
    button.disabled = false;
    button.textContent = "Generate My Estimate";
  }
}

function money(value) {
  return "$" + Math.round(value || 0).toLocaleString();
}

function safeNumber(value) {
  return Number(value || 0).toLocaleString();
}

function fullImageUrl(path) {
  if (!path) return "";
  if (path.startsWith("http")) return path;
  return EPM_BACKEND_BASE + path;
}

function renderEstimate(data) {
  const result = document.getElementById("epmResult");
  const m = data.metrics || {};
  const q = data.quote || { lineItems: [], subtotal: 0, discountRate: 0, savings: 0, total: 0 };

  lastEstimateText = buildEstimateText(data);

  let html = '';

  html += '<div class="epm-section">';
  html += '<h3>Property Views</h3>';
  html += '<div class="image-grid">';
  html += '<div class="image-card"><strong>Aerial View</strong><img src="' + fullImageUrl(data.images && data.images.satellite) + '" alt="Aerial property view"></div>';
  html += '<div class="image-card"><strong>Street View</strong><img src="' + fullImageUrl(data.images && data.images.street) + '" alt="Street view property image"></div>';
  html += '</div>';
  html += '</div>';

  html += '<div class="epm-section">';
  html += '<h3>EPM Home Profile</h3>';
  html += '<div class="metric"><span>Property</span><strong>' + data.property.formattedAddress + '</strong></div>';
  html += '<div class="metric"><span>Property Type</span><strong>' + (m.propertyType || "Residential") + '</strong></div>';
  html += '<div class="metric"><span>Stories</span><strong>' + (m.stories || "—") + '</strong></div>';
  html += '<div class="metric"><span>Parcel Area</span><strong>' + safeNumber(m.parcelAreaSqFt) + ' sq ft</strong></div>';
  html += '<div class="metric"><span>Living Area</span><strong>' + safeNumber(m.livingAreaSqFt) + ' sq ft</strong></div>';
