  html += '<div class="metric"><span>Fence</span><strong>' + safeNumber(m.fenceLinearFt) + ' linear ft</strong></div>';
  html += '<div class="metric"><span>Roof Area</span><strong>' + safeNumber(m.roofAreaSqFt) + ' sq ft</strong></div>';
  html += '<div class="metric"><span>Estimated Windows</span><strong>' + safeNumber(m.windowCount) + '</strong></div>';
  html += '<div class="metric"><span>Confidence</span><strong>' + (m.confidence || "working estimate") + '</strong></div>';
  html += '</div>';

  html += '<div class="epm-section">';
  html += '<h3>Estimated Quote</h3>';

  q.lineItems.forEach(function(item) {
