  html += '<a class="epm-action-btn secondary" href="' + EPM_PHONE + '">Call EPM</a>';
  html += '<button class="epm-action-btn outline" onclick="copyEstimate()">Copy Estimate</button>';
  html += '<button class="epm-action-btn outline" onclick="window.print()">Print Estimate</button>';
  html += '</div>';

  result.innerHTML = html;
}

function buildEstimateText(data) {
  const m = data.metrics || {};
  const q = data.quote || { lineItems: [], subtotal: 0, discountRate: 0, savings: 0, total: 0 };

  let text = "EPM Estimated Quote\\n\\n";
  text += "Property: " + data.property.formattedAddress + "\\n\\n";

  text += "EPM Home Profile\\n";
  text += "Stories: " + (m.stories || "") + "\\n";
  text += "Parcel Area: " + (m.parcelAreaSqFt || "") + " sq ft\\n";
  text += "Living Area: " + (m.livingAreaSqFt || "") + " sq ft\\n";
  text += "Lawn Area: " + (m.lawnAreaSqFt || "") + " sq ft\\n";
  text += "Driveway: " + (m.drivewaySqFt || "") + " sq ft\\n";
  text += "Walkway: " + (m.walkwaySqFt || "") + " sq ft\\n";
  text += "Entry / Porch: " + (m.entryPorchSqFt || "") + " sq ft\\n";
  text += "Sidewalk: " + (m.sidewalkSqFt || "") + " sq ft\\n";
  text += "Total Surface: " + (m.totalSurfaceSqFt || "") + " sq ft\\n";
  text += "Fence: " + (m.fenceLinearFt || "") + " linear ft\\n";
  text += "Roof Area: " + (m.roofAreaSqFt || "") + " sq ft\\n";
  text += "Windows: " + (m.windowCount || "") + "\\n";
  text += "Confidence: " + (m.confidence || "") + "\\n\\n";

  text += "Services\\n";
  q.lineItems.forEach(function(item) {
    text += "- " + item.name + ": " + money(item.price) + " (" + item.calculation + ")\\n";
  });

  text += "\\nSubtotal: " + money(q.subtotal);
  text += "\\nBundle Discount: " + Math.round((q.discountRate || 0) * 100) + "%";
  text += "\\nYou Save: " + money(q.savings);
  text += "\\nEstimated Total: " + money(q.total);
  text += "\\n\\nFinal pricing is confirmed after EPM reviews the property.";

  return text;
}

function emailEstimate() {
  if (!lastEstimateText) {
    alert("Generate an estimate first.");
    return;
  }

  window.location.href = "mailto:?subject=" + encodeURIComponent("Your EPM Estimated Quote") + "&body=" + encodeURIComponent(lastEstimateText);
}

function copyEstimate() {
  if (!lastEstimateText) {
    alert("Generate an estimate first.");
    return;
  }

  navigator.clipboard.writeText(lastEstimateText).then(function() {
    alert("Estimate copied.");
  });
}
